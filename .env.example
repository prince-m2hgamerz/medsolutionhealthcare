# Supabase
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Site
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Rollbar Error Monitoring
NEXT_PUBLIC_ROLLBAR_CLIENT_TOKEN=your_rollbar_client_token
NEXT_PUBLIC_ROLLBAR_ENV=development

# Email Handler Worker (Cloudflare)
EMAIL_WORKER_URL=https://medsolution-email-handler.your-subdomain.workers.dev
EMAIL_WORKER_TOKEN=your_email_worker_token

# Telegram Bot Alerts (admin notifications)
TELEGRAM_BOT_TOKEN=your_bot_token_from_botfather
TELEGRAM_ADMIN_CHAT_IDS=comma_separated_chat_ids
